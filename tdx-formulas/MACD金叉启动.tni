{MACD金叉启动选股}
{条件选股公式 - 金叉 + 多头排列}

DIF:=EMA(C,12)-EMA(C,26);
DEA:=EMA(DIF,9);
MACDH:=2*(DIF-DEA);

{金叉条件}
GC:=CROSS(DIF,DEA);
GCZERO:=GC AND DIF<0;  {零轴下金叉 — 强反转}
GCNORMAL:=GC AND DIF>0; {零轴上金叉 — 继续走强}

{多头加速}
STRONG:=DIF>DEA AND DIF>REF(DIF,2) AND DIF>0;

{RSI 配合}
RSI14:=SMA(MAX(C-REF(C,1),0),14,1)/SMA(ABS(C-REF(C,1)),14,1)*100;
RSISTRONG:=RSI14>50 AND RSI14>REF(RSI14,1);

{放量}
AV20:=MA(V,20);
VUP:=V>AV20*1.2;

{综合}
SELECT:(GCZERO OR GCNORMAL OR STRONG) AND RSISTRONG AND VUP;
