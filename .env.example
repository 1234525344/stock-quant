# ============ AI API Key (至少配置一个) ============
# DeepSeek API Key — 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# AIHubMix API 聚合平台 Key — 在 https://aihubmix.com 获取
# 支持 DeepSeek / Claude / GPT / MiMo 等模型
# AIHUBMIX_API_KEY=your-aihubmix-key-here

# ============ WxPusher 微信推送 (可选) ============
# 在 https://wxpusher.zjiecode.com 注册获取
# WXPUSHER_APP_TOKEN=AT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WXPUSHER_UIDS=UID_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ 部署配置 (可选) ============
# 公网访问地址 (用于分享页面生成链接和二维码)
# PUBLIC_URL=https://your-domain.com

# 通达信本地数据目录 (不填则使用HTTP数据源: 新浪/腾讯/东方财富)
# TDX_ROOT=/path/to/new_tdx64

# CORS 允许的源 (默认: *)
# CORS_ORIGIN=https://your-domain.com

# Python 可执行文件 (默认: python3 on Linux, python on Windows)
# PYTHON_BIN=python3
