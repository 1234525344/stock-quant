{
  "name": "stock-quant",
  "version": "2.1.0",
  "description": "量化交易平台 — 多因子Alpha · 组合优化 · 风险归因",
  "author": "QuantLab",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop stock-quant",
    "pm2:restart": "pm2 restart stock-quant",
    "pm2:logs": "pm2 logs stock-quant",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build-qlib": "docker-compose build --build-arg INSTALL_QLIB=true"
  },
  "build": {
    "appId": "com.quantlab.stock-quant",
    "productName": "量化交易平台",
    "copyright": "Copyright © 2026 QuantLab",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "src/**/*.js",
      "src/**/*.py",
      "src/**/*.json",
      "public/**/*",
      "config/**/*",
      "package.json",
      "!src/**/*.bak",
      "!**/__pycache__/**",
      "!**/__tests__/**",
      "!**/coverage/**"
    ],
    "extraResources": [
      {
        "from": "python/",
        "to": "python/",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "量化交易平台_v${version}.exe"
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "iconv-lite": "^0.7.2",
    "openai": "^4.73.0",
    "sql.js": "^1.14.1",
    "ws": "^8.20.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "docx": "^9.6.1",
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "exceljs": "^4.4.0",
    "jest": "^30.4.2",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "pm2": "^7.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xlsx-populate": "^1.21.0"
  }
}
